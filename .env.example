# Supabase
# Disponibles en: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — SOLO server-side (createAdminClient en lib/supabase/admin.ts).
# NUNCA exponer con prefijo NEXT_PUBLIC_. Disponible en el mismo panel que las de arriba.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API
# Disponible en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Email (OPCIONAL) — notificación al docente cuando un alumno entrega un
# ejercicio personalizado. Si se deja vacío, la notificación in-app sigue
# funcionando igual; solo se omite el email. Requiere una cuenta en
# https://resend.com (gratis hasta 3000 emails/mes) con un dominio
# verificado para RESEND_FROM_EMAIL.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
